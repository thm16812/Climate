ne-aware datetime values to timezone-naive datetime values\n","resampled_df.index = resampled_df.index.tz_localize(None)\n","\n","#####\n","#Change Dates depending on desired dataset\n","#####\n","\n","# Display the resampled DataFrame (optional)\n","#print(resampled_df) remove hashtag if you need to debug\n","# Trim the resampled data to the specified date range\n","start_date = '2019-03-22'\n","end_date = '2023-03-26'\n","trimmed_resampled_df = resampled_df[start_date:end_date]\n","\n","# Save the trimmed and resampled data back to a new Excel file (optional)\n","resampled_file_name = '2007raceResults.xlsx'\n","trimmed_resampled_df.to_excel(resampled_file_name)\n","\n","#####\n","#Change Dates depending on desired dataset\n","#####\n","\n","# Create a new DataFrame to store results\n","results_df = pd.DataFrame(columns=['Date', 'Temperature', 'Dewpoint', 'Wind Chill', 'Heat Index', 'Wind Speed', 'Wind Direction','Precipitation'])\n","# Calculate the temperature on specific dates\n","specific_dates = ['2019-03-22', '2019-03-23', '2019-03-24', '2019-03-25', '2019-03-26',  '2020-03-22', '2020-03-23', '2020-03-24', '2020-03-25', '2020-03-26',  '2021-03-22', '2021-03-23', '2021-03-24', '2021-03-25', '2021-03-26',  '2022-03-22', '2022-03-23', '2022-03-24', '2022-03-25', '2022-03-26',  '2023-03-22', '2023-03-23', '2023-03-24', '2023-03-25', '2023-03-26']\n","\n","#'2012-10-06', '2012-10-07', '2012-10-08', '2012-10-09', '2012-10-10','2013-10-06', '2013-10-07', '2013-10-08', '2013-10-09', '2013-10-10','2014-10-06', '2014-10-07', '2014-10-08', '2014-10-09', '2014-10-10','2015-10-06', '2015-10-07', '2015-10-08', '2015-10-09', '2015-10-10','2016-10-06', '2016-10-07', '2016-10-08', '2016-10-09','2016-10-10'\n","\n","# List of specific times you want to calculate average temperatures for\n","specific_times = ['00:00:00', '01:00:00', '02:00:00', '03:00:00', '04:00:00', '05:00:00', '06:00:00', '07:00:00', '08:00:00', '09:00:00', '10:00:00', '11:00:00', '12:00:00', '13:00:00', '14:00:00', '15:00:00', '16:00:00', '17:00:00', '18:00:00', '19:00:00', '20:00:00', '21:00:00', '22:00:00', '23:00:00']\n","\n","# Iterate through both specific dates and specific times\n","for date in specific_dates:\n","    for specific_time in specific_times:\n","        specific_date_data = trimmed_resampled_df[date]\n","        specific_time_data = specific_date_data[specific_date_data.index.time == pd.to_datetime(specific_time).time()]\n","\n","        # Calculate the average temperature, excluding NaN values\n","        average_temperature = np.nanmean(specific_time_data['Air T'])\n","\n","        # Calculate the average dewpoint\n","        average_dewpoint = np.nanmean(specific_time_data['Dewpoint'])\n","\n","        # Calculate the average wind chill\n","        average_wind_chill = np.nanmean(specific_time_data['Wind Chill'])\n","\n","        #Calculate the average heat index\n","        average_heat_index = np.nanmean(specific_time_data['Heat Index'])\n","\n","        #Calculate the avearage wind speed\n","        average_wind_speed = np.nanmean(specific_time_data['Wind SPD'])\n","\n","        #Calculate the average wind direction\n","        average_wind_direction = np.nanmean(specific_time_data['Wind DIR'])\n","\n","        #Calculate the average hourly precipitation\n","        #average_1hour_precip = np.nanmean(specific_time_data['1 hr Precip'])\n","\n","        # Append data to results DataFrame\n","        statement = f\"Temperature at {specific_time} on {date}: {average_temperature:.2f}\"\n","        results_df = results_df.append({'Date': date, 'Time': specific_time, 'Temperature': average_temperature, 'Dewpoint': average_dewpoint, 'Wind Chill': average_wind_chill, 'Heat Index':average_heat_index, 'Wind SPD':average_wind_speed, 'Wind DIR':average_wind_direction}, ignore_index=True)\n","\n","        #'1 hr Precip':average_1hour_precip\n","\n","# Calculate the overall average of the average temperatures for each specific time\n","overall_averages = []